#!/usr/bin/env bash

pkill -9 -f ddc.py
polybar-msg cmd quit
killall polybar
for monitor in $(bspc query -M --names); do
  if ! xrandr | grep -q "^$monitor connected"; then
    bspc monitor $monitor -r
    xrandr --output $monitor --off
  fi
done

