	name = tomasz13nocon
[credential]
	helper = store
[init]
	defaultBranch = master
[merge]
	conflictstyle = zdiff3
[push]
	default = upstream

[core]
	pager = delta
	autocrlf = input
[pager]
	branch = false
	stash = false
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	dark = true


[diff]
	colorMoved = default
	tool = vimdiff
[pull]
	ff = only
